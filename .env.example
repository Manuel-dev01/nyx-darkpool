# ============================================================================
# docker-compose overrides. Copy to `.env` and edit as needed — compose reads it
# automatically. All values have sane defaults, so the stack runs with NO .env.
# ============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=nyx
POSTGRES_PASSWORD=nyx
POSTGRES_DB=nyx

# --- Engine -----------------------------------------------------------------
NYX_LOG_LEVEL=info
# Persist at-rest blob encryption across restarts (hex, 32 bytes). Unset → an
# ephemeral key is generated at startup (encryption on, orders not persisted).
NYX_BLOB_KEY=
# Require a valid ed25519 signature on every POST /orders (the web app always
# signs). Set to "true" to enforce. Leave blank to verify-when-present.
NYX_REQUIRE_ORDER_SIG=

# --- On-chain settlement (OPT-IN; off by default) ---------------------------
# The engine container has no Linux `stellar` CLI, so on-chain settle is an
# opt-in host/testnet step. To enable from compose you'd supply a reachable CLI
# + funded identity; otherwise the matcher stops after storing the proof.
NYX_SOROBAN_CONTRACT_ID=
NYX_SOROBAN_NETWORK=testnet
NYX_SOROBAN_SOURCE=nyx-engine
