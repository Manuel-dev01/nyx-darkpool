# ─── Nyx Darkpool — root .gitignore ────────────────────────────────────────

# Environment / secrets
.env
.env.*
*.local
*.key
*.pem
secrets/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json

# ─── Golang (/engine) ──────────────────────────────────────────────────────
/engine/bin/
/engine/dist/
/engine/vendor/
*.exe
*.exe~
*.test
*.out
coverage.out
coverage.html

# ─── Node / Circom toolchain (/circuits) ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
/circuits/build/
/circuits/**/*.r1cs
/circuits/**/*.sym
/circuits/**/*_js/
# Trusted-setup artifacts (large; regenerated by scripts/compile_circuit.sh)
*.ptau
*.zkey
# Keep committed verification keys / sample proofs explicitly
!**/verification_key.json
!**/proof.json
!**/public.json

# ─── Rust / Soroban (/contracts) ───────────────────────────────────────────
target/
**/*.rs.bk
*.wasm
Cargo.lock.orig
.stellar/

# ─── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/
