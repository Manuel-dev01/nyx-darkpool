# ─── Nyx Darkpool — root .gitignore ────────────────────────────────────────

# Environment / secrets
.env
.env.*
# …but DO track the committed templates (no secrets, just documented defaults).
!.env.example
!**/.env.example
*.local
*.key
*.pem
secrets/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json

# ─── Golang (/engine) ──────────────────────────────────────────────────────
/engine/bin/
/engine/dist/
/engine/vendor/
*.exe
*.exe~
*.test
*.out
coverage.out
coverage.html

# ─── Node / Circom toolchain (/circuits) ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
/circuits/build/
/circuits/**/*.r1cs
/circuits/**/*.sym
/circuits/**/*_js/
# Trusted-setup artifacts (large; regenerated by scripts/compile_circuit.sh)
*.ptau
*.zkey
# Keep committed verification keys / sample proofs explicitly
!**/verification_key.json
!**/proof.json
!**/public.json

# ─── Rust / Soroban (/contracts) ───────────────────────────────────────────
target/
**/*.rs.bk
*.wasm
Cargo.lock.orig
.stellar/
# Soroban test snapshots are regenerated by `cargo test`.
**/test_snapshots/

# ─── Toolchain binaries ────────────────────────────────────────────────────
# Prebuilt circom downloaded by scripts/install_circom.sh (platform-specific
# build artifact; also caught by the global *.exe rule above).
/scripts/bin/

# ─── Playwright (web e2e) ──────────────────────────────────────────────────
test-results/
playwright-report/
.playwright/

# ─── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Cloud deploy: force-track the two runtime proving artifacts ─────────────
# The engine image bakes these (~2.5 MB total) so it proves SELF-CONTAINED on
# Vercel/Railway with no host bind-mount. Re-include the parent dirs first (git
# can't re-include a file whose parent dir is excluded), then re-exclude the dir
# contents and allow only the wasm. Everything else under circuits/build/
# (ptau/r1cs/sym/intermediate zkeys) stays ignored by the rules above. These two
# files MUST match the deployed testnet verifier's verification key.
!/circuits/build/
/circuits/build/*
!/circuits/build/darkpool_match_final.zkey
!/circuits/build/darkpool_match_js/
/circuits/build/darkpool_match_js/*
!/circuits/build/darkpool_match_js/darkpool_match.wasm

.vercel
